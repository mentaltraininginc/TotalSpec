{
  "scopeName": "source.totalspec",
  "name": "Total Spec",
  "patterns": [
    { "include": "#conditionals" },
    { "include": "#condition-brackets" },
    { "include": "#strings-double" },
    { "include": "#strings-single" },
    { "include": "#backtick-code" },
    { "include": "#functions" },
    { "include": "#shell-variables" },
    { "include": "#http-methods" },
    { "include": "#booleans" },
    { "include": "#cross-references" },
    { "include": "#na-marker" },
    { "include": "#checkmarks" },
    { "include": "#numbers" },
    { "include": "#file-paths" },
    { "include": "#arrows" }
  ],
  "repository": {
    "conditionals": {
      "comment": "Conditional keywords at start of line or after list marker (- )",
      "match": "(?:^|(?<=^- )|(?<=^  - ))(If|When|Unless|While|For each|For all)\\b",
      "captures": {
        "1": { "name": "keyword.control.conditional.totalspec" }
      }
    },
    "condition-brackets": {
      "comment": "Bracketed conditions like [true], [false], [found], [not found], [yes], [no]",
      "match": "\\[(true|false|found|not found|yes|no|exists|gone|drifted|no drift|missing|present|ambiguous)\\]",
      "name": "keyword.control.condition.totalspec"
    },
    "strings-double": {
      "name": "string.quoted.double.totalspec",
      "match": "\"[^\"]*\""
    },
    "strings-single": {
      "name": "string.quoted.single.totalspec",
      "match": "'[^']*'"
    },
    "backtick-code": {
      "name": "markup.inline.raw.string.totalspec",
      "match": "`[^`]+`"
    },
    "functions": {
      "match": "\\b([A-Z][a-zA-Z0-9]*(?:Async)?)\\s*\\(",
      "captures": {
        "1": { "name": "entity.name.function.totalspec" }
      }
    },
    "shell-variables": {
      "name": "variable.other.constant.totalspec",
      "match": "\\$[A-Z_][A-Z0-9_]*"
    },
    "http-methods": {
      "name": "keyword.other.http-method.totalspec",
      "match": "\\b(GET|POST|PUT|PATCH)\\b"
    },
    "booleans": {
      "name": "constant.language.boolean.totalspec",
      "match": "\\b(true|false|null|none|None|YES|NO)\\b"
    },
    "cross-references": {
      "name": "entity.name.tag.totalspec",
      "match": "\\bB\\d+-D\\d+\\b"
    },
    "na-marker": {
      "name": "comment.line.na.totalspec",
      "match": "\\bN/A\\b"
    },
    "checkmarks": {
      "patterns": [
        {
          "name": "markup.inserted.checkmark.totalspec",
          "match": "[\\u2713\\u2714]"
        },
        {
          "name": "markup.deleted.crossmark.totalspec",
          "match": "[\\u2717\\u2718\\u2715\\u2716]"
        }
      ]
    },
    "numbers": {
      "name": "constant.numeric.totalspec",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    },
    "file-paths": {
      "name": "string.unquoted.path.totalspec",
      "match": "(?<=\\s|^)/[a-zA-Z0-9_.\\-/]+/?(?=\\s|$|\\)|,|\\])"
    },
    "arrows": {
      "name": "keyword.operator.arrow.totalspec",
      "match": "[\\u2192\\u2190\\u2194]|->|<-|=>"
    }
  }
}
